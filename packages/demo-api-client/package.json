{
  "name": "demo-api-client",
  "private": true,
  "type": "module",
  "exports": {
    "./fetch": "./src/orval/custom-fetch.ts",
    "./api/*": "./.generated/orval/api/*.ts",
    "./schema/*": "./.generated/orval/schema/*/index.ts",
    "./zod/*": "./.generated/orval/zod/*.ts",
    "./msw": "./src/msw/index.ts"
  },
  "scripts": {
    "clean": "rimraf dist .generated",
    "check": "pnpm check-types && pnpm lint",
    "check-types": "tsc -b --noEmit",
    "lint": "eslint .",
    "format": "eslint --fix .",
    "generate": "orval --config ./orval.config.ts",
    "dev": "orval --watch --config ./orval.config.ts"
  },
  "dependencies": {
    "ofetch": "catalog:",
    "zod": "catalog:",
    "msw": "catalog:",
    "@faker-js/faker": "catalog:",
    "@vendor/typespec-validation": "workspace:*"
  },
  "devDependencies": {
    "vite": "catalog:",
    "@types/node": "catalog:",
    "orval": "catalog:",
    "tsdown": "catalog:",
    "concurrently": "10.0.3",
    "demo-api-spec": "workspace:*",
    "@orval/zod": "workspace:*",
    "@vendor/tsconfig": "workspace:*",
    "@vendor/tsdown-config": "workspace:*"
  }
}
