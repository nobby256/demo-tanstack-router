{
  "name": "demo-tanstack-router",
  "private": true,
  "engines": {
    "pnpm": ">=11.x.x"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "clean": "rimraf .turbo && turbo run clean",
    "check": "prettier --check . && turbo run check",
    "dev": "turbo run react-app#dev",
    "build": "prettier --check . && turbo run build",
    "format": "turbo run format && prettier --write .",
    "nuke": "turbo run clean && rimraf **/.turbo && rimraf '**/node_modules'"
  },
  "devDependencies": {
    "turbo": "catalog:",
    "rimraf": "catalog:",
    "prettier": "catalog:",
    "eslint": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-perfectionist": "catalog:"
  }
}
