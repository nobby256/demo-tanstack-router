{
  "name": "@vendor/typespec-validation",
  "version": "1.0.0",
  "type": "module",
  "exports": {
    ".": {
      "typespec": "./tsp/index.tsp",
      "default": "./dist/index.mjs"
    },
    "./zod": "./dist/zod.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf .turbo dist",
    "nuke": "rimraf .turbo dist node_modules",
    "build": "tsdown",
    "check": "tsc -b tsconfig.json"
  },
  "peerDependencies": {
    "zod": "catalog:",
    "@typespec/compiler": "catalog:"
  },
  "dependencies": {
    "@typespec/openapi": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "typescript": "catalog:",
    "tsdown": "catalog:",
    "rimraf": "catalog:",
    "@vendor/tsconfig": "workspace:*",
    "@vendor/tsdown-config": "workspace:*"
  }
}
