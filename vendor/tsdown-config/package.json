{
  "name": "@vendor/tsdown-config",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./dist/config.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "clean": "rimraf dist",
    "check": "pnpm check-types && pnpm lint",
    "lint": "eslint .",
    "check-types": "tsc -b --noEmit",
    "build": "tsdown",
    "format": "eslint --fix ."
  },
  "devDependencies": {
    "typescript": "catalog:",
    "tsdown": "catalog:",
    "rimraf": "catalog:",
    "@vendor/tsconfig": "workspace:*"
  }
}
